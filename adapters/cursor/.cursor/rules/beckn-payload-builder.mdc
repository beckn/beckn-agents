  "fulfillment:format": "Parquet",
  "fulfillment:fileSizeBytes": 2468000000,
  "fulfillment:maxDownloads": 5,
  "fulfillment:downloadsUsed": 0,
  "fulfillment:termsUrl": "https://data.example.com/terms/ems-hourly-2025",
